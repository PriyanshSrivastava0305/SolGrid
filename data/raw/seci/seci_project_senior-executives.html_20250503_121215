        //All Validations
        function validatedecimal(e) {
            //var val = e;
            var e = event || evt; // for trans-browser compatibility
            var charCode = e.which || e.keyCode;

            //Check for only numeric and dot not allowed
            //if (charCode == 46 || charCode == 45) {
            //    alert("Only numeric Value allowed");
            //    return false;
            //}
            //Check for only numeric and dot allowed
            if (!(charCode == 46 || !(charCode != 45) || !(charCode != 43) || (charCode >= 48 && charCode <= 57))) {
                alert("Only numeric Value allowed");
                return false;
            }
            return true;
        }

        //Emai Validation
        function ValidateEmail(id) {
            var mailformat = /^\w+([\.-]?\w+)*@\w+([\.-]?\w+)*(\.\w{2,3})+$/;
            var EmailID = id;
            var Enteredmail = document.getElementById("" + EmailID + "").value;
            if (Enteredmail.match(mailformat)) {
                return "1";
            }
            else {
                return "0";
            }
        }
        function CheckUniqueCsrNumber(Number1) {
            var regex = /^[A-Z]{3}[0-9]{4}[0-9]{4}/;
            var searchText = Number1;

            if (searchText.match(regex)) {
                return "1";
            }
            else {
                return "0";
            }
        }

        // File Extension and size Check
        function fileextensioncheck(file, _id) {
            var ext = file.split(".");
            ext = ext[ext.length - 1].toLowerCase();

            var arrayExtensions = ["pdf"];
            if (arrayExtensions.lastIndexOf(ext) == -1) {
                alert("Only pdf file are allowed.");
                document.getElementById(_id).value = "";
            }
            if (ext == "pdf") {
                debugger
                var uploadField = document.getElementById(_id).files[0].size;

                if (uploadField > 1048576) {
                    alert("File size is greater than 1 MB not allowed.");
                    document.getElementById(_id).value = "";
                }
            }
        }

